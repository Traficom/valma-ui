  "license": "EUPL-1.2",
  "config": {
    "forge": "./forge-config.cjs"
  },
  "type": "commonjs",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "babel-standalone": "^6.26.0",
    "chart.js": "^4.5.1",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "decompress": "^4.2.1",
    "del": "^8.0.0",
    "electron-dl": "^4.0.0",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^11.0.2",
    "lodash": "^4.17.23",
    "python-shell": "^3.0.1",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-tooltip": "^5.30.0",
