{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "jsx": "react-jsx",

    "strict": false,
    "noImplicitAny": false,

    "allowJs": true,
    "checkJs": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "outDir": "dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out"]
}